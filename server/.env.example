NODE_ENV=development
PORT=5000

# MongoDB (URL-encode special chars in password, e.g. @ -> %40)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/aimi?retryWrites=true&w=majority&appName=AIMI

# JWT
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI (Groq is OpenAI-compatible)
AI_API_KEY=your-groq-api-key
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.3-70b-versatile

# CORS
CLIENT_URL=http://localhost:3000

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aimi.app

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Add these to server/.env to enable Google sign-in:
# 1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# 2. Authorized redirect URI: http://localhost:5000/api/auth/google/callback
# 3. Restart the server after saving .env
